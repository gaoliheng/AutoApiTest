[
  {
    "id": 1,
    "name": "正常注册-包含邀请码",
    "api_path": "/api/v1/auth/register",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json"
    },
    "params": {},
    "body": {
      "email": "john.doe@example.com",
      "invite_code": "ABC123",
      "password": "SecurePass123",
      "username": "john_doe_2026"
    },
    "expected_status": 201,
    "assertions": [
      {
        "expected": 201,
        "type": "status_code"
      },
      {
        "expected": 20000,
        "path": "$.code",
        "type": "json_path"
      },
      {
        "expected": "$NOT_NULL",
        "path": "$.data.user_id",
        "type": "json_path"
      },
      {
        "expected": "$NOT_NULL",
        "path": "$.data.access_token",
        "type": "json_path"
      }
    ],
    "created_at": "2026-03-07T02:44:31",
    "updated_at": "2026-03-07T02:44:31"
  },
